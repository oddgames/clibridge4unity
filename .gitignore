# Everything excluded by default
*

# Repo structure: clibridge4unity/ + Package/ + root files
!clibridge4unity/
!clibridge4unity/**
!Package/
!Package/**
!vscode-extension/
!vscode-extension/**
!README.md
!CLAUDE.md
!SUMMARY.md
!CHANGELOG.md
!LICENSE
!ConsoleUnityBridge.sln
!pyproject.toml
!install.ps1
!deploy.ps1
!.gitignore
!.claude/
!.claude/**
.claude/settings.local.json
!tests/
!tests/**

# Build outputs
clibridge4unity/bin/
clibridge4unity/obj/

# VSCode extension build artifacts (re-excluded after the allowlist above)
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix
# Embedded-extension staging: the .vsix is a build artifact; .gitkeep keeps the folder
clibridge4unity/vscode/*.vsix

# Python generated
__pycache__/
*.py[cod]

# Unity generated
Library/
Temp/
Logs/
UserSettings/
obj/

# OS
.DS_Store
Thumbs.db
